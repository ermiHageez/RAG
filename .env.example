# LLM — Ollama (local, no API key needed)
# Pull models:
#   ollama pull qwen3-embedding:4b
#   ollama pull gemma3:4b
#   ollama pull qwen3:8b
#   ollama pull llama3.1:8b
OLLAMA_BASE_URL=http://localhost:11434
# Context window — lower = less CPU/memory. gemma2:2b defaults to 8k; 2048 is safe
OLLAMA_NUM_CTX=2048
# Threads — physical cores minus 1 to leave headroom. Auto-detected if unset.
OLLAMA_NUM_THREADS=7

# Groq API key (fallback when local Ollama fails or times out)
# Get yours at https://console.groq.com/keys
GROQ_API_KEY=
# Groq model override (default: llama-3.1-8b-instant)
# GROQ_MODEL=gemma2-9b-it

# Google Custom Search API (optional — without these, mock data is used)
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

# n8n (optional — without this, mock acknowledgment returned)
N8N_WEBHOOK_URL=

# Tender portals (optional, defaults used)
PPA_URL=https://www.ppa.gov.et
EGP_URL=https://www.egp.gov.et

# pgvector / PostgreSQL (optional — without these, JSONMemoryStore is used)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=
